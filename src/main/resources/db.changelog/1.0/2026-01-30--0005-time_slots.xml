<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-01-30--0005-time_slots" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="time_slots"/>
            </not>
        </preConditions>
        <createTable tableName="time_slots">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_time_slots_dates"
                             referencedTableName="dates"
                             referencedColumnNames="id"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>



</databaseChangeLog>