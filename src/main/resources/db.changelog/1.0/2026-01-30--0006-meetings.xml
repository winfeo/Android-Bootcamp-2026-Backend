<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-01-30--0006-meetings" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="meetings"/>
            </not>
        </preConditions>
        <createTable tableName="meetings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organizer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_meetings_users"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
            <column name="time_slot_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="fk_meetings_time_slots"
                             referencedTableName="time_slots"
                             referencedColumnNames="id"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
        </createTable>
    </changeSet>



</databaseChangeLog>