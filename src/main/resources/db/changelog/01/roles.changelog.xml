<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.21.xsd">

    <!-- Role table -->
    <changeSet id="1-roles" author="universall">
        <createTable tableName="roles">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Role-Authority join table -->
    <changeSet id="2-role-authorities" author="universall">
        <createTable tableName="role_authorities">
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="authority_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="role_authorities"
                                 baseColumnNames="role_id"
                                 referencedTableName="roles"
                                 referencedColumnNames="id"
                                 constraintName="fk_role_authorities_role"/>
        <addForeignKeyConstraint baseTableName="role_authorities"
                                 baseColumnNames="authority_id"
                                 referencedTableName="authorities"
                                 referencedColumnNames="id"
                                 constraintName="fk_role_authorities_authority"/>
    </changeSet>

</databaseChangeLog>
